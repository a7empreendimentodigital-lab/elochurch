# ─── Desenvolvimento local (SQLite) ───
# Copie para .env:  cp .env.example .env
DATABASE_URL="file:./dev.db"

# ─── Produção (Railway / MySQL) ───
# Troque schema: cp prisma/schema.mysql.prisma prisma/schema.prisma
# DATABASE_URL="mysql://user:password@host:port/elochurch"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-in-production"

# QR da carteirinha abre /membro/[codigo] — no celular use o IP local (ex: http://192.168.1.10:3000)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Super admin (seed)
SUPER_ADMIN_EMAIL="admin@elochurch.com"
SUPER_ADMIN_PASSWORD="Admin@123"
SUPER_ADMIN_NOME="Super Administrador"

# Recriar todos os dados de demo: DEV_SEED_RESET=1 npm run db:seed
