{
  "name": "elochurch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:dev:sync && next dev",
    "dev:turbo": "npm run db:dev:sync && next dev --turbopack",
    "dev:clean": "npm run clean && npm run dev",
    "clean": "rm -rf .next",
    "build": "next build",
    "start": "npm run build && next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts",
    "import:bible": "npx tsx scripts/import-bible.ts",
    "bible:import": "npx tsx scripts/import-bible.ts --file pt_acf.json --full",
    "import:harpa": "npx tsx scripts/import-harpa.ts",
    "harpa:import": "npx tsx scripts/import-harpa.ts --file harpa_crista_640_hinos.json --full",
    "db:dev:sync": "prisma db push && npm run db:seed",
    "db:dev:reset": "DEV_SEED_RESET=1 npm run db:dev:sync",
    "reset:system": "tsx scripts/reset-system.ts",
    "db:fix:mysql-text": "tsx scripts/fix-mysql-text-columns.ts",
    "db:use:mysql": "cp prisma/schema.mysql.prisma prisma/schema.prisma && prisma generate",
    "db:use:sqlite": "cp prisma/schema.sqlite.prisma prisma/schema.prisma && prisma generate",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@prisma/client": "^6.9.0",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3"
  }
}
